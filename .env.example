# Data source mode: replay (default, dev and demo) or live.
# A ?mode= query param on any screen or API call overrides per request.
SUPERSUB_MODE=replay

# Replay pacing: feed seconds per wall second, clamped to 1..60.
# Override per session with ?speed= on the match screen.
REPLAY_SPEED=30
# Feed seconds of pre-match included before the replayed kickoff.
REPLAY_PREROLL_SECONDS=90

# TxLINE access, the spike's token approach: run the Phase 0 spike's
# "npm run auth" once and copy jwt and apiToken from its .tokens.json.
# The bundled France v Morocco replay works WITHOUT these; they are needed
# for live mode and for replaying any other recent fixture on demand.
TXLINE_NETWORK=devnet
TXLINE_JWT=
TXLINE_API_TOKEN=

# Supabase project (server-side only; the browser never sees these).
# The anon key is sufficient: the schema ships permissive RLS policies for
# this phase.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Signs the anonymous player-identity cookie (Phase 2). Any long random
# string; a fixed dev fallback is used when unset, so set this anywhere
# shared.
SUPERSUB_SESSION_SECRET=

# Match report generation (Phase 2), model claude-sonnet-4-6. Optional:
# without a key every report falls back to the deterministic template and
# the app keeps working.
ANTHROPIC_API_KEY=

# Service-role key (SECRET, full DB access, bypasses RLS). NOT used by
# the app: the deployed app only inserts/selects/updates via the anon
# key. Required ONLY by the destructive maintenance scripts
# (purge-test-players, reset-demo, smoke-signing), which cannot delete
# with the anon key since migration 0006. Set it locally to run those;
# never commit it, never give it a NEXT_PUBLIC_ name, never add it to
# the app's Vercel env. From Supabase dashboard > Settings > API.
SUPABASE_SERVICE_ROLE_KEY=
